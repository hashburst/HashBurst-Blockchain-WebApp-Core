# ═══════════════════════════════════════════════════════════════════
# HashBurst WebApp — Configurazione ambiente
# ═══════════════════════════════════════════════════════════════════
#
# ISTRUZIONI:
#   1. Copia questo file in .env
#      cp .env.example .env
#   2. Non modificare mai .env.example direttamente
#   3. Non committare mai .env su git (è già in .gitignore)
#
# HTTPS È OBBLIGATORIO per la Web Crypto API (cifratura chiavi).
# Usare http:// causerebbe il blocco di crypto.subtle nel browser.
# ═══════════════════════════════════════════════════════════════════

# ── Nodo primario ────────────────────────────────────────────────
# Usa SEMPRE il dominio, mai l'IP diretto.
# Se il provider migra IP server, aggiornare il DNS di hashburst.io.
VITE_HASHBURST_NODE_PRIMARY=https://hashburst.io/api

# ── Nodi di fallback (failover automatico nel codice) ────────────
# Separati da virgola, il client li prova se il  primario non risponde.
VITE_HASHBURST_NODES_FALLBACK=https://hashburst.io/api

# ── IPFS ─────────────────────────────────────────────────────────
VITE_IPFS_GATEWAY=https://hashburst.io/ipfs
VITE_IPFS_API=https://hashburst.io/ipfs-api

# ── HVM (Smart Contracts) ────────────────────────────────────────
VITE_HVM_ENDPOINT=https://hashburst.io/hvm

# ── Rete ─────────────────────────────────────────────────────────
VITE_CHAIN_ID=1337
VITE_NETWORK_NAME=HashBurst Mainnet

# ── Timeout e retry (millisecondi) ───────────────────────────────
VITE_NODE_TIMEOUT_MS=5000
VITE_NODE_MAX_RETRIES=3
